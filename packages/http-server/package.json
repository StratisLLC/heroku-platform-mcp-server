{
  "name": "@heroku-mcp/http-server",
  "version": "0.2.0",
  "description": "Hosted HTTP MCP server for Heroku Platform. Streamable HTTP transport, Heroku OAuth sign-in, Postgres-backed encrypted token store, per-user audit log, admin UI.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "herokumcp-platform-server": "./dist/bin.js"
  },
  "files": [
    "dist",
    "migrations",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "VITEST_INTEGRATION=1 vitest run test/integration",
    "lint": "eslint src test",
    "format": "prettier --write src test",
    "format:check": "prettier --check src test"
  },
  "dependencies": {
    "@heroku-mcp/core": "workspace:*",
    "@heroku-mcp/platform": "workspace:*",
    "@hono/node-server": "^1.13.7",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "hono": "^4.6.14",
    "pg": "^8.13.1",
    "ws": "^8.18.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@types/ws": "^8.5.13",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}

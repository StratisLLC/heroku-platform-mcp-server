{
  "name": "@heroku-mcp/platform",
  "version": "0.0.0",
  "description": "Customer-facing Heroku Platform MCP server (stdio). Phase 1: account + apps tiers, read-only.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index-stdio.js",
  "types": "./dist/index-stdio.d.ts",
  "bin": {
    "herokumcp-platform": "./dist/index-stdio.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "VITEST_INTEGRATION=1 vitest run test/integration",
    "lint": "eslint src test",
    "format": "prettier --write src test",
    "format:check": "prettier --check src test"
  },
  "dependencies": {
    "@heroku-mcp/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}

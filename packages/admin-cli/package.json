{
  "name": "@heroku-mcp/admin-cli",
  "version": "0.0.0",
  "description": "Operator CLI for the hosted Heroku MCP server: users, tokens, audit, status, migrations.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "herokumcp-admin": "./dist/bin.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "echo no-integration-tests-for-admin-cli && exit 0",
    "lint": "eslint src test",
    "format": "prettier --write src test",
    "format:check": "prettier --check src test"
  },
  "dependencies": {
    "@heroku-mcp/core": "workspace:*",
    "@heroku-mcp/http-server": "workspace:*",
    "commander": "^12.1.0",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6"
  }
}
